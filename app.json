{
  "expo": {
    "name": "PräFix",
    "slug": "prafix-app",
    "version": "1.0.0",
    "description": "Master German separable verbs with a fun quiz game",
    "orientation": "portrait",
    "scheme": "prafix",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prafix.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#001d3d"
      },
      "package": "com.prafix.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
